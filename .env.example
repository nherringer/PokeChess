# Copy this file to .env and fill in values before running docker compose.
# Generate secrets with: openssl rand -hex 32
#
# DATABASE_URL — required by app/config.py. docker-compose.yml sets this for
# pokechess-app from POSTGRES_*; leave blank here when using Compose only.
# Set when running the app outside Compose (see docs/MASTERDOC.md §5.4).
# ENGINE_URL — optional; defaults to http://localhost:5001 in app/config.py.
# Compose sets this for pokechess-app; override if needed.

DATABASE_URL=
ENGINE_URL=

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

JWT_SECRET_KEY=
BOT_API_SECRET=
# TEMP: pre-launch registration gate. Set to require an access code on POST /auth/register.
# Leave blank to allow open registration. Remove for public launch.
REGISTRATION_ACCESS_CODE=
# Set to ALB/VPC CIDR in production (e.g. 10.0.0.0/16). "*" is only safe behind a
# security group that blocks direct access to port 8000 — but even then, production
# must use an explicit CIDR to prevent X-Forwarded-For spoofing of rate-limit keys.
# docker-compose.yml hard-codes "*" for local dev where no ALB is present.
TRUSTED_PROXY_IPS=*

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
